# ── 写正文用的 API(必填) ─────────────────────
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.deepseek.com
LLM_CHAT_MODEL=deepseek-chat
LLM_REASONING_MODEL=deepseek-reasoner
DEEPSEEK_API_KEY=your_deepseek_api_key

# 网关用法(LLM_BASE_URL 指向 api.mrxoad.uk 时填这个,不填 DEEPSEEK_API_KEY)
# API_GATEWAY_TOKEN=your_gateway_token

# ── 监控用的 API(可选,留空则和写作共用) ──────
# 适合用更便宜 / 更快的小模型跑伏笔抽取、L2/L3 检查
# 例:写作用 deepseek-chat, 监控用 qwen-turbo / glm-4-flash / gpt-4o-mini
# MONITORING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MONITORING_CHAT_MODEL=qwen-turbo-latest
# MONITORING_API_KEY=your_monitoring_api_key
# MONITORING_TEMPERATURE=0.2
# MONITORING_MAX_TOKENS=2000

# ── RAG(可选) ────────────────────────────────
# EMBED_BASE_URL=https://api-inference.modelscope.cn/v1
# EMBED_MODEL=Qwen/Qwen3-Embedding-8B
# EMBED_API_KEY=your_modelscope_key
# RERANK_BASE_URL=https://api.jina.ai/v1
# RERANK_MODEL=jina-reranker-v3
# RERANK_API_KEY=your_jina_key
