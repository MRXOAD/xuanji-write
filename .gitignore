examples/*/.webnovel/backups/
examples/*/.webnovel/index.db
examples/*/.webnovel/external_chapters.json
examples/*/.webnovel/*.bak
examples/*/.webnovel/state.json.bak*

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Workspace artifacts
node_modules/
.npm-cache/
dist/
!webnovel-writer/dashboard/frontend/dist/
!webnovel-writer/dashboard/frontend/dist/**
nul
.tmp/
.tmp_*
.tmp_outline_check/
tmp_verify_*/

# Local research / sibling projects (avoid accidental commit)
.sisyphus/
De-AI-Prompt/
