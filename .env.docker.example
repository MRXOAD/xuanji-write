# docker-compose 用,跟 webnovel-writer/templates/workspace/.env.example 字段一致
# cp 到 .env 然后填:
#   cp .env.docker.example .env

# 哪本书(books/<BOOK>/)
BOOK=default

# 写作 API
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.deepseek.com
LLM_CHAT_MODEL=deepseek-chat
LLM_REASONING_MODEL=deepseek-reasoner
DEEPSEEK_API_KEY=

# 网关备选(用 LLM_BASE_URL=https://api.mrxoad.uk/api/deepseek 时填)
# LLM_GATEWAY_TOKEN=

# 监控 API(可选,缺省 fallback 到写作 API)
# MONITORING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MONITORING_CHAT_MODEL=qwen-turbo-latest
# MONITORING_API_KEY=
